# Supabase (대시보드 → Settings → API)
# 프로젝트 ref: kcwddfxsqanccvribmeu
NEXT_PUBLIC_SUPABASE_URL=https://kcwddfxsqanccvribmeu.supabase.co

# Legacy API Keys 탭의 anon 키, 또는 새 API Keys의 Publishable 키
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_또는_publishable_키

# 새 키만 쓸 경우(선택): NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...

# 이메일 인증 사용 시 Supabase Auth URL 설정에 추가:
# http://localhost:3000/auth/callback
# (배포 도메인도 동일 경로로 등록)

# DB 마이그레이션을 터미널에서 직접 적용할 때 (선택)
# Dashboard → Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@...
# 적용: npm run db:apply

# AI 코칭 (OpenAI) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# 선택: 기본 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# /admin 사이트 설정 저장·이미지 업로드 API — Dashboard → Settings → API → service_role (서버 전용, 절대 클라이언트에 넣지 마세요)
# SUPABASE_SERVICE_ROLE_KEY=...
# Storage 버킷 site-assets: supabase/migrations/0003_site_assets_storage.sql 을 Supabase SQL Editor에서 실행

# 관리자 이메일(쉼표로 여러 명). 로그인한 사용자 이메일과 일치해야 /admin 및 저장 API 사용 가능.
# 배포(production)에서는 반드시 설정하세요. 비어 있으면 /admin 접근이 막힙니다.
# ADMIN_EMAILS=you@example.com
# 또는 단일: ADMIN_EMAIL=you@example.com
